# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production-xyz123
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Database (SQLite par défaut pour le POC local) ────────────────────────────
# Laisser vide = SQLite (aucune installation requise)
DATABASE_URL=

# ─── Redis (optionnel pour Celery async) ───────────────────────────────────────
# Laisser vide = mode synchrone (recommandé pour POC local)
REDIS_URL=

# ─── IA : Groq (LLM + Whisper STT gratuit) ────────────────────────────────────
# Créez un compte sur https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=gsk_your_key_here

# ─── CORS (URL du frontend Expo web) ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081
